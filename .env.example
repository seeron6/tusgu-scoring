# Copy to .env.local for local dev. For GitHub Pages set these as repo secrets
# (NEXT_PUBLIC_*) and pipe them into the build step in .github/workflows/deploy.yml.

# Supabase project — create one at https://app.supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Password to gate Scores / Leaderboard / Awards / Sync / Setup pages.
# Anyone visiting the site with this password can write data.
# Default is the value below — change it for production.
NEXT_PUBLIC_APP_PASSWORD=internalcomp26

# When deployed to https://<user>.github.io/<repo>/ set this to "/<repo>".
# Leave blank for a custom domain or local dev.
NEXT_PUBLIC_BASE_PATH=
